<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fashion_primary"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Background Decorative Elements -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/bg_circle_gradient"
        android:alpha="0.1"
        android:layout_gravity="top|start"
        android:layout_marginTop="-200dp"
        android:layout_marginStart="-200dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Logo Container -->
            <LinearLayout
                android:id="@+id/logoContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/brandLogo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.3"
                    android:text="VIBE"
                    android:textColor="@color/vibe_yellow"
                    android:textSize="80sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="8"
                    android:shadowDy="8"
                    android:shadowRadius="12" />

                <View
                    android:layout_width="120dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="-8dp"
                    android:background="@color/vibe_yellow" />

                <TextView
                    android:id="@+id/tagline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:alpha="0.9"
                    android:letterSpacing="0.4"
                    android:text="STREETWEAR"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/welcomeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="32dp"
                android:text="Welcome Back"
                android:textAppearance="?attr/textAppearanceHeadline5"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/emailLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Email"
                android:textColorHint="@android:color/darker_gray"
                app:hintTextColor="@color/vibe_yellow"
                app:boxStrokeColor="@color/vibe_yellow"
                app:boxBackgroundColor="#3D4446"
                app:startIconDrawable="@android:drawable/ic_dialog_email"
                app:startIconTint="@color/vibe_yellow">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/emailEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="textEmailAddress" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/passwordLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:hint="Password"
                android:textColorHint="@android:color/darker_gray"
                app:hintTextColor="@color/vibe_yellow"
                app:boxStrokeColor="@color/vibe_yellow"
                app:boxBackgroundColor="#3D4446"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="@color/vibe_yellow"
                app:startIconDrawable="@android:drawable/ic_lock_idle_lock"
                app:startIconTint="@color/vibe_yellow">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/passwordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:inputType="textPassword" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="CONTINUE"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/fashion_primary"
                app:backgroundTint="@color/vibe_yellow"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
