<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fashion_primary"
    android:clipChildren="false"
    android:clipToPadding="false">

    <!-- Background Decorative Elements -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:background="@drawable/bg_circle_gradient"
        android:alpha="0.1"
        android:layout_gravity="bottom|start"
        android:layout_marginBottom="-200dp"
        android:layout_marginStart="-200dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="How can we help?"
            android:textAppearance="?attr/textAppearanceHeadline4"
            android:textStyle="bold"
            android:textColor="@color/vibe_yellow"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/contactSupportCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#3D4446"
            app:strokeWidth="0dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_call"
                    app:tint="@color/vibe_yellow"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Contact Support"
                    android:layout_marginStart="20dp"
                    android:textColor="@color/white"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/faqCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#3D4446"
            app:strokeWidth="0dp"
            android:layout_marginBottom="16dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="20dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_menu_help"
                    app:tint="@color/vibe_yellow"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Frequently Asked Questions"
                    android:layout_marginStart="20dp"
                    android:textColor="@color/white"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Support is available 24/7.\nYour satisfaction is our priority."
            android:gravity="center"
            android:textColor="@android:color/darker_gray"
            android:textAppearance="?attr/textAppearanceBodyMedium"/>

    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
